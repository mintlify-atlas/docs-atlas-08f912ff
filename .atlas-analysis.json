  "keyFeatures": [
    "Full JSON Schema validation supporting drafts 6, 7, 2019-09, and 2020-12",
    "Schema generation from .NET types with attribute-driven customization",
    "Random JSON data generation conforming to a given schema",
    "JSON Path querying (RFC 9535) with custom function support",
    "JSON Pointer navigation (RFC 6901) and Relative JSON Pointer",
    "JSON Patch application and generation (RFC 6902)",
    "JSON Logic rule evaluation with custom operator support",
    "JSON-e template evaluation for data-structure parameterization",
    "YAML to JsonNode conversion via YamlDotNet integration",
    "ASP.NET Core integration for automatic request body validation",
    "System.Text.Json-native with AOT support"
  ],
  "publicApiSurface": [
    "JsonSchema.FromText(content)",
    "JsonSchema.FromFile(fileName)",
    "JsonSchema.Evaluate(instance, options)",
    "JsonSchemaBuilder.FromType<T>()",
    "JsonSchemaBuilder.Build()",
    "JsonSchema.GenerateData()",
    "JsonPath.Parse(pathString)",
    "JsonPath.Evaluate(rootNode)",
    "JsonPointer.Parse(pointerString)",
    "JsonPointer.Create<T>(expression)",
    "JsonPointer.Evaluate(element)",
    "JsonPatch.Apply(document)",
    "JsonNode.CreatePatch(target)",
    "JsonLogic.Apply(rule, data)",
    "JsonE.Evaluate(template, context)",
    "YamlNode.ToJsonNode()",
    "JsonConverter.ToJsonNode(yamlStream)"
  ]
